    set_property IOSTANDARD LVCMOS33 [get_ports {cathodes[2]}]
set_property PACKAGE_PIN V8 [get_ports {cathodes[3]}]
    set_property IOSTANDARD LVCMOS33 [get_ports {cathodes[3]}]
