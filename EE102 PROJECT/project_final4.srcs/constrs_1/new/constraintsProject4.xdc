# Buttons
#set_property PACKAGE_PIN U18 [get_ports thumb_btn]
 #   set_property IOSTANDARD LVCMOS33 [get_ports thumb_btn]
set_property PACKAGE_PIN U18 [get_ports reset]
    set_property IOSTANDARD LVCMOS33 [get_ports reset]    
    
    
set_property PACKAGE_PIN T18 [get_ports upper_btn]
    set_property IOSTANDARD LVCMOS33 [get_ports upper_btn]
    
