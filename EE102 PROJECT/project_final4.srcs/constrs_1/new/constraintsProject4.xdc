    set_property IOSTANDARD LVCMOS33 [get_ports {cathodes[4]}]
set_property PACKAGE_PIN V5 [get_ports {cathodes[5]}]
    set_property IOSTANDARD LVCMOS33 [get_ports {cathodes[5]}]
